"""Tests for the {{ project_slug }} pipeline.

Run from the repo root with::

    uv run pytest projects/{{ project_slug }} --no-cov
"""

from __future__ import annotations

import importlib.util
from pathlib import Path
from types import ModuleType

from ds import Settings

PIPELINE_PATH = Path(__file__).resolve().parent.parent / "pipeline.py"


def _load_pipeline() -> ModuleType:
    """Load the sibling ``pipeline.py`` by path (no package import needed)."""
    spec = importlib.util.spec_from_file_location("{{ project_slug }}_pipeline", PIPELINE_PATH)
    assert spec is not None and spec.loader is not None
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


def test_run_returns_metrics(tmp_path: Path) -> None:
    pipeline = _load_pipeline()
    settings = Settings(data_dir=tmp_path / "data")
    metrics = pipeline.run(tmp_path / "out", settings=settings)
    assert isinstance(metrics, dict)


def test_run_creates_output_dir(tmp_path: Path) -> None:
    pipeline = _load_pipeline()
    settings = Settings(data_dir=tmp_path / "data")
    out = tmp_path / "out"
    pipeline.run(out, settings=settings)
    assert out.is_dir()
